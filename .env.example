# Supabase — create a project at https://supabase.com and copy these from
# Project Settings > API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# PostHog — create a project at https://posthog.com and copy the project API key
VITE_POSTHOG_KEY=phc_your_project_key
# Optional: override the PostHog ingestion host (defaults to https://us.i.posthog.com)
# VITE_POSTHOG_HOST=https://eu.i.posthog.com

# Foursquare Places API — used for geo-enrichment of listings
# Get a free key at https://developer.foursquare.com
FOURSQUARE_API_KEY=your-foursquare-api-key

# Resend — used for alert email dispatch (issue 011)
# Create an account at https://resend.com
RESEND_API_KEY=re_your_resend_key

# OpenAI — used for preference extraction and AI ranking
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key
